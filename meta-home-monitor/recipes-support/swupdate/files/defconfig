#
# Home Monitor OS — SWUpdate Configuration (ADR-0008)
#
CONFIG_HAVE_DOT_CONFIG=y

#
# General
#
CONFIG_DEFAULT_CONFIG_FILE="/etc/swupdate.cfg"
CONFIG_SCRIPTS=y
CONFIG_HW_COMPATIBILITY=y
CONFIG_HW_COMPATIBILITY_FILE="/etc/hwrevision"
CONFIG_SW_VERSIONS_FILE="/etc/sw-versions"

#
# Socket Paths
#
CONFIG_SOCKET_CTRL_PATH=""
CONFIG_SOCKET_PROGRESS_PATH=""
CONFIG_SOCKET_REMOTE_HANDLER_DIRECTORY="/tmp/"

#
# Handlers
#
CONFIG_RAW=y
CONFIG_SHELLSCRIPTHANDLER=y
CONFIG_ARCHIVE=y

#
# U-Boot integration (A/B switching)
#
CONFIG_BOOTLOADER_DEFAULT_UBOOT=y
CONFIG_UBOOT=y
CONFIG_UBOOT_FWENV="/etc/fw_env.config"

#
# Systemd
#
CONFIG_SYSTEMD=y

#
# Build
#
CONFIG_CROSS_COMPILE=""
CONFIG_SYSROOT=""
CONFIG_EXTRA_LDLIBS=""

#
# Disable unneeded features (keep binary small for Zero 2W)
#
# CONFIG_CURL is not set
# CONFIG_CURL_SSL is not set
# CONFIG_MTD is not set
# CONFIG_LUA is not set
# CONFIG_FEATURE_SYSLOG is not set
# CONFIG_SURICATTA is not set
# CONFIG_WEBSERVER is not set
# CONFIG_MONGOOSE is not set
# CONFIG_SIGNED_IMAGES is not set
# CONFIG_RDIFFHANDLER is not set
